	(gr_text "AWKB - A Weird Keyboard\n	 PCB designed by JW"
		(at 158.496 128.016 342)
		(layer "F.SilkS" knockout)
		(uuid "99292259-e567-4947-b4c9-6c0051aa6fc5")
		(effects
			(font
				(size 0.7 0.7)
				(thickness 0.15)
				(italic yes)
			)
			(justify left)
		)
	)
	(gr_text "Why Weird is Wonderful (and Bankable)\n\n	Being weird means being noticeably \n	different. It means being or doing \n	something that makes other people \n	stare, or laugh, applaud, or boo. \n	And it's something we all need to \n	cultivate.\n\n				-- Forbes (2011)"
		(at 171.0436 96.012 0)
		(layer "B.SilkS")
		(uuid "045ab265-61c7-44c4-83ac-f7c9da0d8599")
		(effects
			(font
				(size 0.6 0.6)
				(thickness 0.125)
				(bold yes)
				(italic yes)
			)
			(justify left bottom mirror)
		)
	)
